  "scripts": {
    "dev": "next dev",
    "build": "next build && next export -o build/",
    "build:storybook": "build-storybook -o build-storybook && node scripts/draco-storybook",
    "deploy": "aws s3 sync --delete build/ s3://hamish-portfolio-site",
    "deploy:storybook": "aws s3 sync --delete build-storybook s3://hamish-portfolio-storybook",
    "deploy:functions": "cd functions && npm run deploy",
    "start": "next start",
    "test": "echo 'write some tests'",
    "storybook": "start-storybook -p 9009 -h localhost",
    "prettier": "prettier '**/*.{js,jsx,ts,tsx,css,md}' --check --write",
    "lint": "yarn lint:scripts; yarn lint:styles",
    "lint:scripts": "eslint '**/*.{js,jsx,ts,tsx}' --config .eslintrc --fix",
    "lint:styles": "stylelint '**/*.{css,scss,ts,tsx}' --config .stylelintrc --fix"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not ie 11",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "npm": ">=8.6.0",
    "node": ">=18.0.0"
  }
